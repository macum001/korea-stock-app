{
  "name": "korea-stock-backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node -r tsconfig-paths/register src/server.ts",
    "build": "tsc && node scripts/copySchema.cjs",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "dart:sync-companies": "ts-node -r tsconfig-paths/register src/scripts/syncCompanies.ts",
    "disclosure:sync": "ts-node -r tsconfig-paths/register src/scripts/syncDisclosures.ts",
    "test:push": "ts-node -r tsconfig-paths/register src/scripts/testPush.ts",
    "test:dart": "ts-node -r tsconfig-paths/register src/scripts/testDart.ts",
    "test:disclosure-classifier": "ts-node -r tsconfig-paths/register src/scripts/testClassifier.ts",
    "test:disclosure-cache": "ts-node -r tsconfig-paths/register src/scripts/testCache.ts",
    "verify:env": "node scripts/verifyEnv.cjs",
    "snapshot:finalize": "ts-node -r tsconfig-paths/register src/scripts/finalizeMarketSnapshots.ts",
    "benchmark:realtime-cache": "ts-node -r tsconfig-paths/register src/scripts/benchmarkRealtimeCache.ts",
    "benchmark:ws-fanout": "ts-node -r tsconfig-paths/register src/scripts/wsFanoutLoadTest.ts",
    "test:chaos:redis": "bash ../scripts/chaos/redis-restart.sh",
    "test:chaos:realtime": "bash ../scripts/chaos/kill-realtime.sh",
    "test:candle-buckets": "ts-node -r tsconfig-paths/register src/scripts/testCandleBuckets.ts",
    "disclosure:backfill-category": "ts-node -r tsconfig-paths/register src/scripts/backfillCategoryType.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "adm-zip": "^0.5.10",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "fast-xml-parser": "^4.3.2",
    "firebase-admin": "^14.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "unzipper": "^0.10.14",
    "ws": "^8.14.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.43",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.10.9",
    "@types/unzipper": "^0.10.9",
    "@types/ws": "^8.5.10",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.2"
  }
}
